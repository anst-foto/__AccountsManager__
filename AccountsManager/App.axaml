<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AccountsManager.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    
    <Application.Resources>
        <x:String x:Key="Title">Менеджер аккаунтов</x:String>
        <x:String x:Key="Title_AuthWindow">Авторизация</x:String>
        <x:String x:Key="Title_MainWindow">Учёт аккаунтов</x:String>
    </Application.Resources>
</Application>